<mujoco model="Rope">
  <include file="scene.xml"/>

  <compiler autolimits="true"/>

  <option solver="CG" tolerance="1e-6" timestep=".001"/>

  <visual>
    <map stiffness="100"/>
  </visual>

  <worldbody>
    <camera pos="0 -2 3" euler="45 0 0 "/>
    <body name="rope" pos=".1 -.2 1.5">
      <flexcomp type="grid" count="12 1 1" spacing=".1 .1 .1" pos="0 0 0"
                radius=".03" rgba="0 .7 .7 1" name="rope" dim="1" mass="1">
        <edge equality="true"/>
        <contact condim="3" selfcollide="none" conaffinity="0" contype="0"/>
        <pin id="0"/>
      </flexcomp>
    </body>
  </worldbody>  
</mujoco>