<mujoco model="Rope">
  <include file="scene.xml"/>

  <compiler autolimits="true"/>

  <option solver="CG" tolerance="1e-6" timestep=".001"/>

  <visual>
    <map stiffness="100"/>
  </visual>

  <worldbody>
    <camera pos="0 -4 2" euler="70 0 0 "/>
    <body name="rope" pos=".1 -.2 1.5">
      <flexcomp type="grid" count="12 1 1" spacing=".1 .1 .1" pos="-0.5 0 0"
                radius=".03" rgba="0 .7 .7 1" name="rope" dim="1" mass="1">
        <edge equality="true"/>
        <contact condim="3" selfcollide="none" conaffinity="0" contype="0"/>
        <pin id="0"/>
      </flexcomp>
    <flexcomp name="towel" type="grid" count="30 30 1" spacing="0.05 0.05 0.05"
              radius="0.02" dim="2" rgba="1 0.5 0.5 1" pos="0.5 0 0.5" mass=".1" euler="180 0 0">
      <edge equality="true"/>
      <contact condim="3" selfcollide="none" conaffinity="0" contype="0"/>
      <pin id="0 750"/>
    </flexcomp>
    </body>

  </worldbody>
</mujoco>