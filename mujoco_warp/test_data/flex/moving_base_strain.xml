<mujoco model="MovingBaseStrain">
  <include file="scene.xml"/>

  <option solver="CG" tolerance="1e-6" timestep=".001" integrator="implicitfast"/>

  <worldbody>
    <body name="moving_base" pos="0 0 1.5">
      <joint name="slide" type="slide" axis="0 0 1" range="-1 1"/>
      <geom type="box" size=".2 .2 .05" rgba=".2 .2 .2 1"/>
      
      <flexcomp type="grid" count="4 4 4" spacing=".05 .05 .05" pos="0 0 -.1"
                radius=".001" rgba="0 .7 .7 1" mass="1" name="softbody" dof="trilinear" dim="3">
        <edge equality="strain"/>
        <contact selfcollide="none" internal="false" contype="0" conaffinity="0"/>
      </flexcomp>
    </body>
  </worldbody>
</mujoco>
