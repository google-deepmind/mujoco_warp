<mujoco model="skybox_checker">

  <visual>
    <map znear="0.01" zfar="200" />
    <headlight diffuse=".8 .8 .8" ambient=".2 .2 .2" specular="1 1 1" />
  </visual>

  <asset>
    <texture type="skybox" builtin="checker" rgb1="0.05 0.05 0.2" rgb2="0.95 0.95 0.6" width="256" height="256" />
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4" />
    <material name="grid" texture="grid" texrepeat="4 4" texuniform="true" reflectance=".2" />
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" directional="true" />
    <camera name="main" pos="0 0 0.2" xyaxes="1 0 0 0 -0.2 1" resolution="640 480" />

    <geom name="floor" size="4 4 0.05" type="plane" material="grid" />
    <geom name="ball" type="sphere" pos="0 1.2 0.1" size="0.1" rgba="0.9 0.3 0.2 1" />
  </worldbody>

</mujoco>
